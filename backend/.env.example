# Copie este arquivo para .env e preencha com seus valores reais
# Comando: cp .env.example .env

# ==========================================
# BANCO DE DADOS
# ==========================================
DATABASE_URL=postgresql://hineni:hineni123@localhost:5432/hineni_db

# ==========================================
# AUTENTICAÇÃO JWT
# ==========================================
# Gere uma chave segura com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-por-uma-chave-secreta-forte-aqui
ALGORITHM=HS256
# Tempo de expiração do token (em minutos) - 8 horas = 480
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ==========================================
# WHATSAPP (Evolution API - opcional)
# ==========================================
WHATSAPP_API_URL=http://localhost:8080
WHATSAPP_API_KEY=sua-chave-da-evolution-api
WHATSAPP_INSTANCE=hineni

# ==========================================
# APLICAÇÃO
# ==========================================
APP_NAME=Hineni - Escalas da Igreja
DEBUG=True
FRONTEND_URL=http://localhost:8550
